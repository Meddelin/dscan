{
  "include": ["src/**/*.{ts,tsx,js,jsx}"],
  "exclude": [],
  "localLibraries": [
    {
      "libId": "team-kit-backed",
      "matchPattern": "@team/kit-backed",
      "source": { "type": "local-path", "path": "vendor/team-kit-backed" },
      "kind": "partially-beaver-backed"
